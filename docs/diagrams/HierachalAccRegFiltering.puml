@startuml

actor User
participant ":TransactionsList" as List
participant ":CurrencyConverter" as Converter
participant ":Storage" as Storage

== Convert (View Only) ==
User -> Converter : convert(transaction, target)
Converter --> User : converted result

== Confirm ==
User -> List : confirm(transaction)

List -> Converter : applyConversion(...)
Converter --> List : updated transaction

List -> Storage : save(...)
Storage --> List : success

List --> User : "Transaction confirmed"

@enduml
